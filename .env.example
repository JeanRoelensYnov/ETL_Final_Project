# Modèle de configuration. Copier ce fichier vers .env puis renseigner les valeurs.
#   cp .env.example .env   (ou copier-coller sous Windows)
# Le vrai .env n'est jamais versionné.

KAFKA_BOOTSTRAP=localhost:9092

# MySQL (Docker, port hôte 3307 car un MySQL natif occupe déjà 3306)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=etl
MYSQL_PASSWORD=changeme
MYSQL_DB=bourse

# MongoDB (Docker)
MONGO_USER=root
MONGO_PASSWORD=changeme
MONGO_HOST=localhost
MONGO_PORT=27017
